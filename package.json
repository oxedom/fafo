{
  "name": "domain-analyzer",
  "version": "0.1.0",
  "description": "CLI tool that analyzes domains by fetching their JS bundles and using AI to detect frontend stacks",
  "type": "module",
  "bin": {
    "domain-analyzer": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "domain",
    "analyzer",
    "frontend",
    "stack",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "js-beautify": "^1.15.4",
    "openai": "^6.27.0",
    "p-limit": "^7.3.0"
  },
  "devDependencies": {
    "@types/js-beautify": "^1.14.3",
    "@types/node": "^25.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
