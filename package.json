{
  "name": "@oxedom/fafo",
  "version": "0.1.0",
  "description": "CLI that analyzes a website's JS bundles through a chosen research mode (security or product)",
  "type": "module",
  "bin": {
    "fafo": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && cp src/modes.json dist/modes.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "domain",
    "analyzer",
    "frontend",
    "stack",
    "cli"
  ],
  "license": "MIT",
  "author": "oxedom",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oxedom/fafo.git"
  },
  "homepage": "https://github.com/oxedom/fafo#readme",
  "bugs": {
    "url": "https://github.com/oxedom/fafo/issues"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "js-beautify": "^1.15.4",
    "openai": "^6.27.0",
    "p-limit": "^7.3.0"
  },
  "devDependencies": {
    "@types/js-beautify": "^1.14.3",
    "@types/node": "^25.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
